      "rules_of_thumb": [
        {
          "label": "ATM call delta",
          "value": "~0.50"
        },
        {
          "label": "Gamma peaks",
          "value": "ATM, near expiry"
        },
        {
          "label": "Theta accelerates",
          "value": "Last 30 days"
        },
        {
          "label": "Vega largest",
          "value": "ATM, long-dated"
        }
      ],
      "pitfalls": [
        "Treating Greeks as constants — they all change as price/time/IV moves.",
        "Sizing for delta but ignoring gamma → blowups in fast moves.",
        "Selling premium for theta without acknowledging gamma + vega risk."
