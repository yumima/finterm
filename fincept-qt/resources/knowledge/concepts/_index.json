      "rules_of_thumb": [
        {
          "label": "Loss aversion ratio",
          "value": "~2× (losses hurt 2× as much as gains feel good)"
        },
        {
          "label": "Confirmation bias",
          "value": "We seek info that confirms our thesis"
        },
        {
          "label": "Anchoring",
          "value": "First number seen distorts subsequent estimates"
        },
        {
          "label": "Recency bias",
          "value": "Recent events feel more likely than they are"
        }
      ],
      "pitfalls": [
        "Holding losers too long (loss aversion), selling winners too early.",
        "Anchoring to your purchase price as if it has meaning.",
        "Confirmation bias filtering out evidence against your thesis.",
        "Overconfidence after a winning streak — sizing up exactly when you should size down."
      ],
      "external_links": [
