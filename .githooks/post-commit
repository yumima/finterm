#!/usr/bin/env bash
# Post-commit hook intentionally a no-op.
#
# README "Today's commits" used to be appended via a post-commit hook that
# created a follow-up `docs(readme): update today's commits` commit after
# every user commit. That doubled the commit count and was removed.
# README updates now happen in .githooks/pre-commit and ride into the
# user's own commit. See tools/update_todays_commits.py for the rationale.

exit 0
